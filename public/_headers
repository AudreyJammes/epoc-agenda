/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*
  # Empêche le clickjacking (chargement de l'Agenda dans une iframe tierce)
  X-Frame-Options: DENY

  # Empêche le MIME sniffing
  X-Content-Type-Options: nosniff

  # Limite les infos transmises lors d'un clic sortant
  Referrer-Policy: strict-origin-when-cross-origin

  # Désactive les APIs sensibles non utilisées
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # — script-src  : bundle Vite ('self')
  # — connect-src : Supabase REST + Realtime (wss)
  # — img-src     : data/blob (avatars, icônes PWA)
  # — worker-src  : Service Worker Workbox (blob: généré à la volée)
  # — style-src   : Tailwind et styles inline
  # — frame-src   : aucun embed externe
  Content-Security-Policy: default-src 'self'; script-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-src 'none'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; worker-src blob:; font-src 'self' data:; object-src 'none'; base-uri 'self';
